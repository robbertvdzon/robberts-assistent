# Robberts Assistent — lokale geheimen/config.
#
# Kopieer dit bestand naar `secrets.env` (zelfde map) en vul je eigen waarden in.
# `secrets.env` is gitignored; dit `.example`-bestand is het gedocumenteerde sjabloon.
#
# robberts-assistent-backend zoekt dit bestand automatisch op (AppSecretsLoader):
# eerst `RA_SECRETS_FILE` (indien gezet), anders `secrets.env` of `../secrets.env`
# (dus ook als je de backend vanuit `robberts-assistent-backend/` start, wordt dit
# root-bestand gevonden). Env-vars (bv. in Kubernetes) hebben altijd voorrang boven
# waarden uit dit bestand.

# -- Google-login (robberts-assistent-backend) --------------------------------
# OAuth-client-ID (audience) waartegen Google-ID-tokens worden gevalideerd. Moet
# dezelfde waarde zijn als de GOOGLE_CLIENT_ID waarmee de Flutter-apps gebouwd worden
# (--dart-define). Aanmaken via Google Cloud Console > APIs & Services > Credentials.
RA_GOOGLE_CLIENT_ID=

# Ondertekent (HMAC) het sessie-token dat de backend na een geslaagde Google-login
# afgeeft. Verplicht, willekeurige lange string. Genereer bijvoorbeeld met:
#   openssl rand -hex 32
RA_REMEMBER_SECRET=

# Toegestane, geverifieerde e-mailadressen (komma-gescheiden). Alleen deze adressen
# krijgen een sessie-token, ongeacht een verder geldig Google-token.
# Optioneel; default: robbert@vdzon.com
RA_ALLOWED_EMAILS=robbert@vdzon.com

# Alleen aanzetten in branch-preview-omgevingen: slaat de Google-login volledig over
# zodat de tester-agent zonder account kan inloggen. MOET in productie leeg/false zijn.
# Optioneel; default: false
RA_PREVIEW_SKIP_GOOGLE_AUTH=false

# -- Database (notities) -------------------------------------------------------
# JDBC-URL voor de notities-tabel. Zonder deze env-var valt de backend terug op
# een H2-in-memory-database (prima voor lokaal draaien/tests, leeg na herstart).
# Voor een echte database: gebruik een EIGEN Neon-database/rol, nooit een
# database die al bij een ander product hoort (aparte migratie-geschiedenis!).
# Voorbeeld (Neon): jdbc:postgresql://<host>/<eigen-database>?user=<eigen-rol>&password=<wachtwoord>&sslmode=require
RA_DATABASE_URL=

# -- Chat-assistent (AI) --------------------------------------------------------
# API-key voor OpenAI (chat-assistent met tools voor notities + windmetingen, zie
# robberts-assistent-backend/.../assistant/ai/AiConfig.kt). Zonder deze key (of met
# RA_MOCK_AI=true) gebruikt de backend automatisch een deterministische mock —
# geen kosten, geen netwerkafhankelijkheid. Nooit een echte key in preview zetten.
RA_OPENAI_API_KEY=

# Forceert de mock-ChatModel, ook als RA_OPENAI_API_KEY wél gezet is. Staat altijd
# op true in branch-preview (zie deploy/overlays/preview) en in tests. Optioneel;
# default: false (maar zonder RA_OPENAI_API_KEY is de mock sowieso altijd actief).
RA_MOCK_AI=false

# -- Flutter-apps (build-time, geen backend-secret) ----------------------------
# Zelfde OAuth-client-ID als RA_GOOGLE_CLIENT_ID hierboven, meegegeven aan
# `flutter build ... --dart-define=GOOGLE_CLIENT_ID=...` (robberts_assistent, notities).
# In CI komt dit uit de GitHub Actions-variabele `vars.GOOGLE_CLIENT_ID` (geen secret,
# want een OAuth-client-ID is niet geheim) — hier alleen handig voor lokaal bouwen/testen.
GOOGLE_CLIENT_ID=

# -- Fundament-koppelingen (zie docs/foundation-couplings.md) -------------------
# Alle onderstaande waarden zijn OPTIONEEL. Ontbreekt een groep, dan valt de
# bijbehorende koppeling terug op een stub (LoggingNotifier / in-memory reminders /
# stub-agenda / stub-docs): de backend, tests en CI blijven gewoon groen.

# Telegram-bot (uitgaande berichten, Notifier). Token krijg je van @BotFather;
# chat-id is jouw persoonlijke chat met de bot (op te vragen via getUpdates).
RA_TELEGRAM_BOT_TOKEN=
RA_TELEGRAM_CHAT_ID=

# Firebase (Firestore-database + FCM-push), één service-account voor beide.
# Pad naar de gedownloade service-account-JSON + het project-id.
RA_FIREBASE_CREDENTIALS_FILE=
RA_FIREBASE_PROJECT_ID=

# Google OAuth "offline access" voor Agenda + Docs (read-only). Maak een OAuth-client
# (type Desktop) aan; zet het consent-scherm op "In production" (anders verloopt de
# refresh-token na 7 dagen); haal éénmalig een refresh-token op met de scopes
# calendar.readonly + documents.readonly. De backend maakt zelf korte access-tokens.
RA_GOOGLE_OAUTH_CLIENT_ID=
RA_GOOGLE_OAUTH_CLIENT_SECRET=
RA_GOOGLE_OAUTH_REFRESH_TOKEN=
