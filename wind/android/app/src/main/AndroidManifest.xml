<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android 13+: runtime-permissie om notificaties te posten. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="Wind"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <!--
          Launcher-activity, nu zelf een trampoline-activity (zie
          AnswerTrampolineActivity): geen UI, spreekt/notificeert de huidige
          windsnelheid en sluit direct af. Testopzet om te zien of "Hey
          Google, open Wind" dit gedrag triggert.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/TrampolineTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- App Actions capabilities (shortcuts.xml). -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- Trampoline-activity: "huidige windsnelheid". Geen zichtbaar scherm. -->
        <activity
            android:name=".WindSpeedActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/TrampolineTheme" />

        <!-- Trampoline-activity: "voorspelling". Geen zichtbaar scherm. -->
        <activity
            android:name=".ForecastActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/TrampolineTheme" />

        <!--
          Flutter's build-tooling vereist deze v2-embedding-marker ergens in
          het manifest, ook al gebruikt geen enkele activity hier Flutter
          actief (MainActivity is nu een pure trampoline-activity). Zonder
          dit faalt `flutter build apk` met "deleted Android v1 embedding".
        -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
</manifest>
